{
	"title": "rc420_template_title",
	"device_type": "royalclima_rc420",
	"group": "g-control-panel",

	"device": {
		"name": "Royal Clima RC 420",
		"id": "royalclima_rc420",
		"guard_interval_us": 3500,

		"groups": [
			{
				"title": "Control",
				"id": "control"
			},
			{
				"title": "Status",
				"id": "status"
			}
		],

		"channels": [
			{
				"name": "Active",
				"reg_type": "holding",
				"address": 0,
				"type": "switch",
				"format": "u16",
				"group": "control"
			},
			{
				"name": "Mode",
				"reg_type": "holding",
				"address": 1,
				"type": "value",
				"format": "u16",
				"enum": [0, 1, 2],
				"enum_titles": [
					"Ventilation",
					"Cooling",
					"Heating"
				],
				"group": "control"
			},
			{
				"name": "Fan Speed",
				"reg_type": "holding",
				"address": 2,
				"type": "value",
				"format": "u16",
				"enum": [0, 1, 2, 3],
				"enum_titles": [
					"Off",
					"Low",
					"Medium",
					"High"
				],
				"group": "control"
			},
			{
				"name": "Auto Fan Speed",
				"reg_type": "holding",
				"address": 3,
				"type": "switch",
				"format": "u16",
				"group": "control"
			},
			{
				"name": "Temperature Setpoint",
				"reg_type": "holding",
				"address": 6,
				"type": "range",
				"format": "u16",
				"min": 16,
				"max": 35,
				"group": "control"
			},
			{
				"name": "Panel Lock",
				"reg_type": "holding",
				"address": 7,
				"type": "switch",
				"format": "u16",
				"group": "control"
			},
			{
				"name": "Room Temperature",
				"reg_type": "holding",
				"address": 4,
				"type": "temperature",
				"format": "u16",
				"readonly": true,
				"group": "status"
			},
			{
				"name": "Temperature Alarm",
				"reg_type": "holding",
				"address": 5,
				"type": "switch",
				"format": "u16",
				"readonly": true,
				"group": "status"
			}
		],

		"translations": {
